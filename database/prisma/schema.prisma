generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CommonStatus {
  ENABLED
  DISABLED
}

enum CustomerRegionType {
  CHINA
  OVERSEAS
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

enum OrderLineFulfillmentMode {
  PRODUCTION
  STOCK
  REWORK
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ProductionNoticeType {
  QUANTITY_INCREASE
  QUANTITY_DECREASE
  ORDER_CANCELLED
  MATERIAL_ADDED
  TASK_WITHDRAWN
}

enum ProductionNoticeStatus {
  PENDING
  ACKNOWLEDGED
}

enum ProductionNoticeTarget {
  PRODUCTION
  WAREHOUSE
}

enum InventoryStatus {
  AVAILABLE
  USED
}

enum InventoryTransactionType {
  IN
  OUT
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

model Customer {
  id           String          @id @default(uuid())
  customerCode String          @unique
  customerName String
  contactName  String?
  contactPhone String?
  address      String?
  regionType   CustomerRegionType @default(CHINA)
  country      String             @default("中国")
  province     String?
  state        String?
  district     String?
  city         String?
  detailAddress String?
  remark       String?
  status       CommonStatus    @default(ENABLED)
  contacts     CustomerContact[]
  orders       CustomerOrder[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([customerName])
  @@index([status])
}

model CustomerContact {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contactName  String
  contactPhone String?
  title        String?
  remark       String?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerId])
  @@index([contactName])
}

/// 物料基础清单，只保存零件编码、名称和默认单位；库存数量仍然从 InventoryBatch 实时计算。
model Material {
  id                String       @id @default(uuid())
  partCode          String       @unique
  partName          String
  unit              String       @default("件")
  partSpecification String?
  status            CommonStatus @default(ENABLED)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([partName])
  @@index([status])
}

/// 流程记忆模板只保存可复用工序组合，不绑定客户、订单或零件号。
model ProcessDefinition {
  id                    String       @id @default(uuid())
  processName           String
  processNameNormalized String       @unique
  searchText            String       @default("")
  remark                String?
  status                CommonStatus @default(ENABLED)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([status, processName])
}

model ProcessTemplate {
  id                     String   @id @default(uuid())
  templateName           String
  templateNameNormalized String   @unique
  steps                  Json
  remark                 String?
  searchText             String   @default("")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([templateName])
  @@index([searchText])
}

/// 订单号永久占用表。订单取消、归档或未来迁移后，订单号仍然不能被其他订单复用。
model OrderNoReservation {
  id                String   @id @default(uuid())
  orderNo           String
  orderNoNormalized String   @unique
  sourceOrderId     String?
  reservedReason    String   @default("ORDER_CREATED")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([orderNo])
  @@index([sourceOrderId])
}

/// 客户订单总表，只保存订单汇总信息；订单零件必须进入 OrderLine。
model CustomerOrder {
  id               String           @id @default(uuid())
  orderNo          String           @unique
  customerId       String
  customer         Customer         @relation(fields: [customerId], references: [id])
  customerCode     String
  customerName     String
  customerSnapshot Json
  orderDate        DateTime
  deliveryDate     DateTime?
  status           OrderStatus      @default(DRAFT)
  remark           String?
  lines            OrderLine[]
  productionTasks  ProductionTask[]
  inventoryBatches InventoryBatch[]
  inventoryReservations InventoryReservation[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([customerId])
  @@index([orderDate])
  @@index([status])
}

/// 订单零件明细表，一个订单可以包含多个零件。
model OrderLine {
  id              String                 @id @default(uuid())
  orderId         String
  order           CustomerOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lineNo          Int
  partCode        String
  partName        String
  drawingNo       String?
  drawingVersion  String?
  drawingFileName String?
  drawingFileUrl  String?
  partThickness   Decimal                @default(1) @db.Decimal(18, 3)
  partSpecification String?
  quantity        Decimal                @db.Decimal(18, 3)
  productionPlanQuantity Decimal          @db.Decimal(18, 3)
  productionPlanSuggestedQuantity Decimal? @db.Decimal(18, 3)
  productionPlanOverrideByCode String?
  productionPlanOverrideByName String?
  productionPlanOverrideByRole String?
  productionPlanOverrideAt DateTime?
  productionPlanOverrideReason String?
  fulfillmentMode OrderLineFulfillmentMode @default(PRODUCTION)
  unit            String
  deliveryDate    DateTime?
  remark          String?
  processSnapshot Json?
  stockSourceSelections Json?
  processSteps    OrderLineProcessStep[]
  productionTasks ProductionTask[]
  inventoryBatches InventoryBatch[]
  inventoryReservations InventoryReservation[]
  inventoryTransactions InventoryTransaction[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([orderId, lineNo])
  @@index([partCode])
  @@index([fulfillmentMode])
}

/// 每个订单零件独立保存生产步骤，避免把流程压成一个长字符串。
model OrderLineProcessStep {
  id          String    @id @default(uuid())
  orderLineId String
  orderLine   OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  stepNo      Int
  processName String
  processRemark String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([orderLineId, stepNo])
  @@index([processName])
}

/// 生产任务由订单零件生成，生产状态只保留第一阶段需要的三种状态。
model ProductionTask {
  id               String           @id @default(uuid())
  productionTaskNo String           @unique
  orderId          String
  order            CustomerOrder    @relation(fields: [orderId], references: [id])
  orderLineId      String
  orderLine        OrderLine        @relation(fields: [orderLineId], references: [id])
  orderNo          String
  customerName     String
  partCode         String
  partName         String
  plannedQuantity  Decimal          @db.Decimal(18, 3)
  completedQuantity Decimal         @default(0) @db.Decimal(18, 3)
  unit             String
  status           ProductionStatus @default(PENDING)
  processSnapshot  Json
  isReplenishment  Boolean          @default(false)
  sourceProductionTaskNo String?
  replenishmentSourceType String?
  replenishmentSourceRequestNo String?
  startedAt        DateTime?
  completedAt      DateTime?
  remark           String?
  inventoryBatch   InventoryBatch?
  processCompletions ProductionProcessCompletion[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([orderId])
  @@index([orderNo])
  @@index([status])
  @@index([partCode])
  @@index([isReplenishment])
  @@index([sourceProductionTaskNo])
  @@index([replenishmentSourceType])
  @@index([replenishmentSourceRequestNo])
}

/// 生产操作人员基础账号，第一阶段只做工序确认需要的账号 ID、姓名、岗位和搜索字段。
model ProductionOperator {
  id             String       @id @default(uuid())
  accountId      String       @unique
  name           String
  role           String
  pinyin         String?
  pinyinInitials String?
  keywords       String[]     @default([])
  idCardMasked   String?
  idCardBound    Boolean      @default(false)
  status         CommonStatus @default(ENABLED)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([name])
  @@index([status])
}

/// 每道工序的完成表单；同一个生产任务的同一道工序只保留当前有效记录。
model ProductionProcessCompletion {
  id                String                         @id @default(uuid())
  productionTaskId  String
  productionTask    ProductionTask                 @relation(fields: [productionTaskId], references: [id], onDelete: Cascade)
  stepNo            Int
  processName       String
  processRemark     String?
  isCompleted       Boolean                        @default(false)
  completedQuantity Decimal                        @default(0) @db.Decimal(18, 3)
  scrapQuantity     Decimal                        @default(0) @db.Decimal(18, 3)
  shortageQuantity  Decimal                        @default(0) @db.Decimal(18, 3)
  shortageMode      String?
  replenishmentTaskNo String?
  managerName       String?
  shortageReason    String?
  shortageResolutionMode String?
  shortageResolutionBy String?
  shortageResolutionReason String?
  shortageResolvedAt DateTime?
  unit              String
  operatorCode      String?
  operatorName      String?
  operatorRole      String?
  completedAt       DateTime?
  quantityOverrideReason String?
  remark            String?
  replenishmentRequests ProductionReplenishmentRequest[]
  logs              ProductionProcessCompletionLog[]
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  @@unique([productionTaskId, stepNo])
  @@index([processName])
  @@index([isCompleted])
  @@index([completedAt])
  @@index([shortageResolutionMode])
}

/// 工序完成表单修改日志，只追加，不覆盖。
model ProductionProcessCompletionLog {
  id                String                      @id @default(uuid())
  completionId      String
  completion        ProductionProcessCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)
  productionTaskId  String
  processName       String
  action            String
  operatorCode      String?
  operatorName      String?
  beforeSnapshot    Json?
  afterSnapshot     Json
  createdAt         DateTime                    @default(now())

  @@index([completionId])
  @@index([productionTaskId])
  @@index([createdAt])
}

/// 生产过程中因报废、缺件发起的补单申请；和订单页面由销售/计划发起的数量增加补单分开记录。
model ProductionReplenishmentRequest {
  id                    String                       @id @default(uuid())
  requestNo             String                       @unique
  sourceType            String                       @default("PRODUCTION_SCRAP")
  status                String                       @default("PENDING")
  orderId               String?
  orderNo               String
  orderLineId           String?
  productionTaskId      String?
  productionTaskNo      String?
  processCompletionId   String?                      @unique
  processCompletion     ProductionProcessCompletion? @relation(fields: [processCompletionId], references: [id], onDelete: SetNull)
  partCode              String
  partName              String
  requestQuantity       Decimal                      @db.Decimal(18, 3)
  scrapQuantity         Decimal                      @default(0) @db.Decimal(18, 3)
  unit                  String
  reason                String
  requestedByCode       String?
  requestedByName       String?
  supervisorName        String?
  supervisorRemark      String?
  approvedAt            DateTime?
  reviewedAt            DateTime?
  replenishmentTaskNo   String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  @@index([status])
  @@index([sourceType])
  @@index([orderNo])
  @@index([productionTaskNo])
  @@index([partCode])
  @@index([createdAt])
}

model ProductionNotice {
  id                 String                 @id @default(uuid())
  noticeNo           String                 @unique
  noticeType         ProductionNoticeType
  status             ProductionNoticeStatus @default(PENDING)
  target             ProductionNoticeTarget @default(PRODUCTION)
  orderId            String?
  orderNo            String
  orderLineId        String?
  productionTaskId   String?
  productionTaskNo   String?
  partCode           String?
  partName           String?
  beforeQuantity     Decimal?               @db.Decimal(18, 3)
  afterQuantity      Decimal?               @db.Decimal(18, 3)
  deltaQuantity      Decimal?               @db.Decimal(18, 3)
  unit               String?
  reason             String
  managerName        String?
  handlingPlan       Json?
  acknowledgedBy     String?
  acknowledgedAt     DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([status])
  @@index([target])
  @@index([target, status])
  @@index([noticeType])
  @@index([orderNo])
  @@index([productionTaskNo])
  @@index([createdAt])
}

model ProductionScrapRecord {
  id                 String   @id @default(uuid())
  scrapNo            String   @unique
  orderId            String?
  orderNo            String
  orderLineId        String?
  productionTaskId   String?
  productionTaskNo   String?
  partCode           String
  partName           String
  quantity           Decimal  @db.Decimal(18, 3)
  unit               String
  reason             String
  sourceRecordType   String
  sourceRecordId     String
  recordDate         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([sourceRecordType, sourceRecordId])
  @@index([orderNo])
  @@index([productionTaskNo])
  @@index([partCode])
  @@index([recordDate])
}

model Warehouse {
  id                    String                 @id @default(uuid())
  warehouseCode         String                 @unique
  warehouseName         String
  status                CommonStatus           @default(ENABLED)
  locations             WarehouseLocation[]
  inventoryBatches      InventoryBatch[]
  inventoryTransactions InventoryTransaction[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model WarehouseLocation {
  id                    String                 @id @default(uuid())
  warehouseId           String
  warehouse             Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  locationCode          String
  locationName          String
  status                CommonStatus           @default(ENABLED)
  inventoryBatches      InventoryBatch[]
  inventoryTransactions InventoryTransaction[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@unique([warehouseId, locationCode])
}

model InventoryBatch {
  id                     String                 @id @default(uuid())
  batchNo                String                 @unique
  partCode               String
  partName               String
  sourceOrderId          String?
  sourceOrder            CustomerOrder?         @relation(fields: [sourceOrderId], references: [id])
  sourceOrderLineId      String?
  sourceOrderLine        OrderLine?             @relation(fields: [sourceOrderLineId], references: [id])
  sourceOrderNo          String?
  sourceCustomerName     String?
  productionTaskId       String?                @unique
  productionTask         ProductionTask?        @relation(fields: [productionTaskId], references: [id])
  sourceProductionTaskNo String?
  sourceKind             String                 @default("NORMAL_ORDER")
  replenishmentSourceType String?
  replenishmentSourceRequestNo String?
  quantity               Decimal                @db.Decimal(18, 3)
  unit                   String
  warehouseId            String
  warehouse              Warehouse              @relation(fields: [warehouseId], references: [id])
  locationId             String?
  location               WarehouseLocation?     @relation(fields: [locationId], references: [id])
  status                 InventoryStatus        @default(AVAILABLE)
  transactions           InventoryTransaction[]
  adjustments            InventoryAdjustment[]
  reservations           InventoryReservation[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@index([partCode])
  @@index([sourceOrderNo])
  @@index([sourceOrderLineId])
  @@index([sourceProductionTaskNo])
  @@index([sourceKind])
  @@index([replenishmentSourceType])
  @@index([replenishmentSourceRequestNo])
  @@index([warehouseId])
  @@index([status])
}

/// 订单保存后对备货库存的预占记录。草稿订单不直接扣库存，提交生产时把 ACTIVE 预占转为 CONSUMED 并生成库存流水。
model InventoryReservation {
  id           String                     @id @default(uuid())
  batchId      String
  batch        InventoryBatch             @relation(fields: [batchId], references: [id])
  orderId      String
  order        CustomerOrder              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderLineId  String?
  orderLine    OrderLine?                 @relation(fields: [orderLineId], references: [id], onDelete: SetNull)
  orderNo      String
  partCode     String
  partName     String
  quantity     Decimal                    @db.Decimal(18, 3)
  unit         String
  status       InventoryReservationStatus @default(ACTIVE)
  statusReason String?
  releasedAt   DateTime?
  consumedAt   DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([batchId, status])
  @@index([orderId, status])
  @@index([orderLineId, status])
  @@index([orderNo])
  @@index([partCode])
}

/// 库存流水只追加记录，用于保留入库 / 出库数量变化。
model InventoryTransaction {
  id                     String                   @id @default(uuid())
  transactionNo          String                   @unique
  transactionType        InventoryTransactionType
  batchId                String?
  batch                  InventoryBatch?          @relation(fields: [batchId], references: [id])
  orderLineId            String?
  orderLine              OrderLine?               @relation(fields: [orderLineId], references: [id], onDelete: SetNull)
  partCode               String
  partName               String
  orderNo                String?
  productionTaskNo       String?
  quantity               Decimal                  @db.Decimal(18, 3)
  unit                   String
  warehouseId            String
  warehouse              Warehouse                @relation(fields: [warehouseId], references: [id])
  locationId             String?
  location               WarehouseLocation?       @relation(fields: [locationId], references: [id])
  transactionTime        DateTime                 @default(now())
  remark                 String?
  sourceRecordType       String?
  sourceRecordId         String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([transactionType])
  @@index([partCode])
  @@index([orderNo])
  @@index([orderLineId])
  @@index([transactionTime])
}

/// 仓库盘点调整记录：库存管理员修改批次数量时必须保留清点工单、清点人、日期和签字信息。
model InventoryAdjustment {
  id                 String         @id @default(uuid())
  adjustmentNo       String         @unique
  batchId            String
  batch              InventoryBatch @relation(fields: [batchId], references: [id])
  partCode           String
  partName           String
  beforeQuantity     Decimal        @db.Decimal(18, 3)
  afterQuantity      Decimal        @db.Decimal(18, 3)
  deltaQuantity      Decimal        @db.Decimal(18, 3)
  unit               String
  countedBy          String
  countedAt          DateTime
  signatureName      String
  attachmentFileName String?
  attachmentFileUrl  String?
  attachmentMimeType String?
  attachmentSize     Int?
  remark             String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([batchId])
  @@index([partCode])
  @@index([countedAt])
  @@index([createdAt])
}
