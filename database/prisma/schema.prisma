generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CommonStatus {
  ENABLED
  DISABLED
}

enum CustomerRegionType {
  CHINA
  OVERSEAS
}

enum OrderStatus {
  DRAFT
  PENDING_PRODUCTION
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

enum OrderLineFulfillmentMode {
  PRODUCTION
  STOCK
  REWORK
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  WAITING_CONFIRMATION
  COMPLETED
  STORED
  CANCELLED
}

enum ProductionNoticeType {
  QUANTITY_INCREASE
  QUANTITY_DECREASE
  ORDER_CANCELLED
  MATERIAL_ADDED
  TASK_WITHDRAWN
}

enum ProductionNoticeStatus {
  PENDING
  ACKNOWLEDGED
}

enum ProductionNoticeTarget {
  PRODUCTION
  WAREHOUSE
}

enum InventoryStatus {
  AVAILABLE
  RESERVED
  USED
  SCRAPPED
}

enum InventoryTransactionType {
  IN
  OUT
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

model Customer {
  id                      String                  @id @default(uuid())
  customerCode            String                  @unique
  customerName            String
  contactName             String?
  contactPhone            String?
  address                 String?
  regionType              CustomerRegionType      @default(CHINA)
  country                 String                  @default("中国")
  province                String?
  state                   String?
  district                String?
  city                    String?
  detailAddress           String?
  remark                  String?
  status                  CommonStatus            @default(ENABLED)
  contacts                CustomerContact[]
  orders                  CustomerOrder[]
  materialApplicabilities MaterialApplicability[]
  modelBoms               ModelBom[]
  modelBomCustomerScopes  ModelBomCustomerScope[]
  materialTransformRules  MaterialTransformRule[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([customerName])
  @@index([status])
}

model CustomerContact {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contactName  String
  contactPhone String?
  title        String?
  remark       String?
  isPrimary    Boolean  @default(false)
  status       CommonStatus @default(ENABLED)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerId])
  @@index([customerId, status])
  @@index([contactName])
}

/// 物料基础清单，只保存零件编码、名称和默认单位；库存数量仍然从 InventoryBatch 实时计算。
model Material {
  id                   String                    @id @default(uuid())
  partCode             String                    @unique
  partName             String
  unit                 String                    @default("件")
  partSpecification    String?
  stockAlertEnabled    Boolean                   @default(false)
  stockAlertQuantity   Decimal?                  @db.Decimal(18, 3)
  status               CommonStatus              @default(ENABLED)
  applicabilities      MaterialApplicability[]
  drawingRevisions     MaterialDrawingRevision[]
  modelBomLines        ModelBomLine[]
  sourceTransformRules MaterialTransformRule[]   @relation("MaterialTransformSource")
  targetTransformRules MaterialTransformRule[]   @relation("MaterialTransformTarget")
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([partName])
  @@index([status])
  @@index([stockAlertEnabled])
}

/// 零件管理常用机型快捷入口。只保存显示顺序，不改变 BOM、零件适用范围、订单或库存。
model MaterialCommonProjectModel {
  id                     String       @id @default(uuid())
  projectModel           String
  projectModelNormalized String       @unique
  sortOrder              Int
  status                 CommonStatus @default(ENABLED)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([sortOrder])
  @@index([status])
}

/// 零件图纸版本。历史图纸不覆盖旧订单，订单行只保存下单时的图纸快照。
model MaterialDrawingRevision {
  id               String         @id @default(uuid())
  materialId       String
  material         Material       @relation(fields: [materialId], references: [id], onDelete: Cascade)
  drawingNo        String
  drawingVersion   String
  drawingDate      DateTime?
  drawingStatus    String?
  drawingFileName  String?
  drawingFileUrl   String?
  isDefault        Boolean        @default(false)
  defaultChangedBy String?
  defaultChangedAt DateTime?
  remark           String?
  status           CommonStatus   @default(ENABLED)
  modelBomLines    ModelBomLine[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([materialId, drawingNo, drawingVersion])
  @@index([materialId, isDefault])
  @@index([materialId, drawingDate])
  @@index([drawingNo])
  @@index([status])
}

/// 机型零件包。用于维护 B3、B5 等标准清单；只做下单推荐基础，不自动创建订单或生产任务。
model ModelBom {
  id                    String                  @id @default(uuid())
  bomName               String
  customerId            String?
  customer              Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerNameSnapshot  String?
  projectModel          String
  customerScopeMode     String                  @default("ALL")
  customerScopeKey      String                  @default("ALL")
  projectModelScopeKey  String
  sourceBomId           String?
  sourceBomNameSnapshot String?
  isCommon              Boolean                 @default(false)
  commonSortOrder       Int?
  remark                String?
  status                CommonStatus            @default(ENABLED)
  customerScopes        ModelBomCustomerScope[]
  lines                 ModelBomLine[]
  diffReviewsAsTarget   ModelBomDiffReview[]    @relation("ModelBomDiffReviewTarget")
  diffReviewsAsSource   ModelBomDiffReview[]    @relation("ModelBomDiffReviewSource")
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@unique([bomName, customerScopeKey, projectModelScopeKey])
  @@unique([customerScopeKey, projectModelScopeKey])
  @@index([customerId])
  @@index([sourceBomId])
  @@index([projectModelScopeKey])
  @@index([isCommon, commonSortOrder])
  @@index([status])
}

/// BOM 客户适用范围。用于表达“全部客户通用”和“勾选指定客户可用”，不自动生成订单或库存。
model ModelBomCustomerScope {
  id                   String       @id @default(uuid())
  bomId                String
  bom                  ModelBom     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  customerId           String
  customer             Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerNameSnapshot String?
  status               CommonStatus @default(ENABLED)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([bomId, customerId])
  @@index([customerId, status])
}

model ModelBomLine {
  id                        String                   @id @default(uuid())
  bomId                     String
  bom                       ModelBom                 @relation(fields: [bomId], references: [id], onDelete: Cascade)
  materialId                String
  material                  Material                 @relation(fields: [materialId], references: [id], onDelete: Restrict)
  partCodeSnapshot          String
  partNameSnapshot          String
  unitSnapshot              String
  partSpecificationSnapshot String?
  partThicknessSnapshot     Decimal?                 @db.Decimal(18, 3)
  lineType                  String                   @default("PART")
  partCategory              String?
  componentNo               String?
  parentComponentNo         String?
  defaultDrawingRevisionId  String?
  defaultDrawingRevision    MaterialDrawingRevision? @relation(fields: [defaultDrawingRevisionId], references: [id], onDelete: SetNull)
  diffReviewsAsSourceLine   ModelBomDiffReview[]     @relation("ModelBomDiffReviewSourceLine")
  diffReviewsAsTargetLine   ModelBomDiffReview[]     @relation("ModelBomDiffReviewTargetLine")
  defaultProcessRoute       String?
  defaultQuantity           Decimal                  @default(1) @db.Decimal(18, 3)
  remark                    String?
  sortOrder                 Int                      @default(0)
  status                    CommonStatus             @default(ENABLED)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  @@index([bomId, materialId])
  @@index([bomId, lineType, sortOrder])
  @@index([bomId, componentNo])
  @@index([bomId, parentComponentNo])
  @@index([defaultDrawingRevisionId])
  @@index([materialId])
  @@index([status])
}

/// 客户 BOM 与来源 BOM 的人工差异核对记录；只记录人工确认，不自动覆盖 BOM 明细。
model ModelBomDiffReview {
  id              String        @id @default(uuid())
  targetBomId     String
  targetBom       ModelBom      @relation("ModelBomDiffReviewTarget", fields: [targetBomId], references: [id], onDelete: Cascade)
  sourceBomId     String
  sourceBom       ModelBom      @relation("ModelBomDiffReviewSource", fields: [sourceBomId], references: [id], onDelete: Cascade)
  reviewKey       String        @unique
  issueKind       String
  sourceLineId    String?
  sourceLine      ModelBomLine? @relation("ModelBomDiffReviewSourceLine", fields: [sourceLineId], references: [id], onDelete: SetNull)
  targetLineId    String?
  targetLine      ModelBomLine? @relation("ModelBomDiffReviewTargetLine", fields: [targetLineId], references: [id], onDelete: SetNull)
  issueTitle      String
  issueDetail     String?
  diffFingerprint String
  fieldsJson      Json?
  reviewedBy      String?
  reviewRemark    String?
  status          CommonStatus  @default(ENABLED)
  reviewedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([targetBomId, sourceBomId])
  @@index([targetBomId, status])
  @@index([sourceBomId])
  @@index([sourceLineId])
  @@index([targetLineId])
  @@index([reviewedAt])
}

/// 零件适用范围。customerScopeKey / projectModelScopeKey 用于避免 PostgreSQL NULL 唯一约束失效。
model MaterialApplicability {
  id                   String       @id @default(uuid())
  materialId           String
  material             Material     @relation(fields: [materialId], references: [id], onDelete: Cascade)
  customerId           String?
  customer             Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerNameSnapshot String?
  projectModel         String?
  customerScopeKey     String       @default("ALL")
  projectModelScopeKey String       @default("ALL")
  remark               String?
  status               CommonStatus @default(ENABLED)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([materialId, customerScopeKey, projectModelScopeKey])
  @@index([customerId])
  @@index([projectModelScopeKey])
  @@index([status])
}

/// 流程记忆模板只保存可复用工序组合，不绑定客户、订单或零件号。
model ProcessDefinition {
  id                    String       @id @default(uuid())
  processName           String
  processNameNormalized String       @unique
  searchText            String       @default("")
  remark                String?
  status                CommonStatus @default(ENABLED)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([status, processName])
}

model ProcessTemplate {
  id                     String       @id @default(uuid())
  templateName           String
  templateNameNormalized String       @unique
  steps                  Json
  remark                 String?
  searchText             String       @default("")
  status                 CommonStatus @default(ENABLED)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([templateName])
  @@index([searchText])
  @@index([status, updatedAt])
}

/// 订单号永久占用表。订单取消、归档或未来迁移后，订单号仍然不能被其他订单复用。
model OrderNoReservation {
  id                String   @id @default(uuid())
  orderNo           String
  orderNoNormalized String   @unique
  sourceOrderId     String?
  reservedReason    String   @default("ORDER_CREATED")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([orderNo])
  @@index([sourceOrderId])
}

/// 客户订单总表，只保存订单汇总信息；订单零件必须进入 OrderLine。
model CustomerOrder {
  id                    String                 @id @default(uuid())
  orderNo               String                 @unique
  customerId            String
  customer              Customer               @relation(fields: [customerId], references: [id])
  customerCode          String
  customerName          String
  customerSnapshot      Json
  orderDate             DateTime
  deliveryDate          DateTime?
  status                OrderStatus            @default(DRAFT)
  remark                String?
  lines                 OrderLine[]
  productionTasks       ProductionTask[]
  inventoryBatches      InventoryBatch[]
  inventoryReservations InventoryReservation[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([customerId])
  @@index([orderDate])
  @@index([status])
}

/// Excel 订单导入会话。一个会话可以连续上传多个文件，最终只创建 DRAFT 订单。
model OrderImportSession {
  id                String            @id @default(uuid())
  status            String            @default("DRAFT")
  createdBy         String?
  committedAt       DateTime?
  committedOrderNos Json?
  files             OrderImportFile[]
  rows              OrderImportRow[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// Excel 导入文件记录，用于识别同一会话内重复上传。
model OrderImportFile {
  id                String             @id @default(uuid())
  sessionId         String
  session           OrderImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileName          String
  storedFileName    String?
  fileHash          String
  sheetName         String
  rowCount          Int                @default(0)
  acceptedRowCount  Int                @default(0)
  duplicateRowCount Int                @default(0)
  createdAt         DateTime           @default(now())
  rows              OrderImportRow[]
  orderLines        OrderLine[]        @relation("OrderLineSourceImportFile")

  @@unique([sessionId, fileHash])
  @@index([sessionId])
  @@index([fileHash])
}

/// Excel 导入原始行快照。后端提交前重新校验，不直接信任 Excel 公式。
model OrderImportRow {
  id                String             @id @default(uuid())
  sessionId         String
  session           OrderImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileId            String
  file              OrderImportFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sourceRowNo       Int
  rowHash           String
  orderBlock        String?
  orderNo           String
  orderDate         DateTime
  customerName      String
  projectModel      String?
  lineType          String
  importSequence    String?
  partCategory      String?
  componentNo       String?
  parentComponentNo String?
  partCode          String
  drawingNo         String?
  partName          String
  partSpecification String?
  partThickness     Decimal            @default(1) @db.Decimal(18, 3)
  orderQuantity     Decimal?           @db.Decimal(18, 3)
  unitUsage         Decimal?           @db.Decimal(18, 3)
  demandQuantity    Decimal            @db.Decimal(18, 3)
  unit              String
  processRoute      String?
  processRemark     String?
  drawingDate       DateTime?
  drawingStatus     String?
  raw               Json
  issues            Json?
  errorCount        Int                @default(0)
  warningCount      Int                @default(0)
  createdAt         DateTime           @default(now())

  @@unique([sessionId, rowHash])
  @@index([sessionId])
  @@index([sessionId, orderNo, sourceRowNo])
  @@index([fileId])
  @@index([orderNo])
  @@index([componentNo])
  @@index([parentComponentNo])
}

/// Excel 零件基础库导入会话。只写入零件主数据，不创建订单、库存或生产任务。
model MaterialImportSession {
  id                     String                           @id @default(uuid())
  status                 String                           @default("DRAFT")
  createdBy              String?
  committedAt            DateTime?
  committedMaterialCodes Json?
  files                  MaterialImportFile[]
  rows                   MaterialImportRow[]
  applicabilityRows      MaterialApplicabilityImportRow[]
  transformRows          MaterialTransformImportRow[]
  createdAt              DateTime                         @default(now())
  updatedAt              DateTime                         @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// 零件基础库导入文件记录。一个会话允许连续上传多个 .xlsx 文件。
model MaterialImportFile {
  id                String                           @id @default(uuid())
  sessionId         String
  session           MaterialImportSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileName          String
  storedFileName    String?
  fileHash          String
  sheetName         String
  rowCount          Int                              @default(0)
  materialRowCount  Int                              @default(0)
  scopeRowCount     Int                              @default(0)
  transformRowCount Int                              @default(0)
  acceptedRowCount  Int                              @default(0)
  duplicateRowCount Int                              @default(0)
  createdAt         DateTime                         @default(now())
  rows              MaterialImportRow[]
  applicabilityRows MaterialApplicabilityImportRow[]
  transformRows     MaterialTransformImportRow[]

  @@unique([sessionId, fileHash])
  @@index([sessionId])
  @@index([fileHash])
}

/// 零件基础库导入原始行快照。提交前后端重新校验，不信任 Excel 公式。
model MaterialImportRow {
  id                 String                @id @default(uuid())
  sessionId          String
  session            MaterialImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileId             String
  file               MaterialImportFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sourceRowNo        Int
  rowHash            String
  partCode           String
  partName           String
  unit               String
  partSpecification  String?
  drawingNo          String?
  drawingVersion     String?
  drawingDate        DateTime?
  drawingStatus      String?
  partThickness      Decimal?              @db.Decimal(18, 3)
  projectModel       String?
  stockAlertEnabled  Boolean?
  stockAlertQuantity Decimal?              @db.Decimal(18, 3)
  remark             String?
  raw                Json
  issues             Json?
  errorCount         Int                   @default(0)
  warningCount       Int                   @default(0)
  createdAt          DateTime              @default(now())

  @@unique([sessionId, rowHash])
  @@index([sessionId])
  @@index([fileId])
  @@index([partCode])
}

/// 零件适用范围 Excel 导入行。提交前必须解析到 Material 和 Customer，不直接信任 Excel 文本。
model MaterialApplicabilityImportRow {
  id           String                @id @default(uuid())
  sessionId    String
  session      MaterialImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileId       String
  file         MaterialImportFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sourceRowNo  Int
  rowHash      String
  partCode     String
  customerCode String?
  customerName String?
  projectModel String?
  remark       String?
  status       CommonStatus          @default(ENABLED)
  raw          Json
  issues       Json?
  errorCount   Int                   @default(0)
  warningCount Int                   @default(0)
  createdAt    DateTime              @default(now())

  @@unique([sessionId, rowHash])
  @@index([sessionId])
  @@index([fileId])
  @@index([partCode])
}

/// 来源加工关系 Excel 导入行。只写建议规则，不自动扣库存或生成生产任务。
model MaterialTransformImportRow {
  id                    String                @id @default(uuid())
  sessionId             String
  session               MaterialImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileId                String
  file                  MaterialImportFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sourceRowNo           Int
  rowHash               String
  sourcePartCode        String
  targetPartCode        String
  customerCode          String?
  customerName          String?
  projectModel          String?
  multiplier            Decimal?              @db.Decimal(18, 3)
  lossRate              Decimal?              @db.Decimal(18, 4)
  defaultProcessRoute   String?
  conversionDescription String?
  remark                String?
  status                CommonStatus          @default(ENABLED)
  raw                   Json
  issues                Json?
  errorCount            Int                   @default(0)
  warningCount          Int                   @default(0)
  createdAt             DateTime              @default(now())

  @@unique([sessionId, rowHash])
  @@index([sessionId])
  @@index([fileId])
  @@index([sourcePartCode])
  @@index([targetPartCode])
}

/// 订单零件明细表，一个订单可以包含多个零件。
/// 来源加工关系。只作为下单和库存来源核对建议，不自动扣库存、不自动生成生产任务。
model MaterialTransformRule {
  id                    String       @id @default(uuid())
  sourceMaterialId      String
  sourceMaterial        Material     @relation("MaterialTransformSource", fields: [sourceMaterialId], references: [id], onDelete: Restrict)
  targetMaterialId      String
  targetMaterial        Material     @relation("MaterialTransformTarget", fields: [targetMaterialId], references: [id], onDelete: Restrict)
  customerId            String?
  customer              Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerNameSnapshot  String?
  projectModel          String?
  customerScopeKey      String       @default("ALL")
  projectModelScopeKey  String       @default("ALL")
  conversionDescription String?
  defaultProcessRoute   String?
  multiplier            Decimal      @default(1) @db.Decimal(18, 3)
  lossRate              Decimal?     @db.Decimal(18, 4)
  remark                String?
  status                CommonStatus @default(ENABLED)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@unique([sourceMaterialId, targetMaterialId, customerScopeKey, projectModelScopeKey])
  @@index([sourceMaterialId])
  @@index([targetMaterialId])
  @@index([customerId])
  @@index([projectModelScopeKey])
  @@index([status])
}

model OrderLine {
  id                              String                   @id @default(uuid())
  orderId                         String
  order                           CustomerOrder            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lineNo                          Int
  partCode                        String
  partName                        String
  drawingNo                       String?
  drawingVersion                  String?
  drawingFileName                 String?
  drawingFileUrl                  String?
  partThickness                   Decimal                  @default(1) @db.Decimal(18, 3)
  partSpecification               String?
  quantity                        Decimal                  @db.Decimal(18, 3)
  productionPlanQuantity          Decimal                  @db.Decimal(18, 3)
  productionPlanSuggestedQuantity Decimal?                 @db.Decimal(18, 3)
  productionPlanOverrideByCode    String?
  productionPlanOverrideByName    String?
  productionPlanOverrideByRole    String?
  productionPlanOverrideAt        DateTime?
  productionPlanOverrideReason    String?
  fulfillmentMode                 OrderLineFulfillmentMode @default(PRODUCTION)
  unit                            String
  deliveryDate                    DateTime?
  remark                          String?
  processSnapshot                 Json?
  stockSourceSelections           Json?
  lineType                        String                   @default("PART")
  partCategory                    String?
  componentNo                     String?
  parentComponentNo               String?
  importSequence                  String?
  sourceImportSessionId           String?
  sourceImportFileId              String?
  sourceImportFile                OrderImportFile?         @relation("OrderLineSourceImportFile", fields: [sourceImportFileId], references: [id], onDelete: SetNull)
  sourceImportFileName            String?
  sourceImportRowNo               Int?
  projectModel                    String?
  drawingDate                     DateTime?
  drawingStatus                   String?
  processSteps                    OrderLineProcessStep[]
  productionTasks                 ProductionTask[]
  inventoryBatches                InventoryBatch[]
  inventoryReservations           InventoryReservation[]
  inventoryTransactions           InventoryTransaction[]
  createdAt                       DateTime                 @default(now())
  updatedAt                       DateTime                 @updatedAt

  @@unique([orderId, lineNo])
  @@index([partCode])
  @@index([fulfillmentMode])
  @@index([lineType])
  @@index([componentNo])
  @@index([parentComponentNo])
  @@index([sourceImportSessionId])
  @@index([sourceImportFileId])
}

/// 每个订单零件独立保存生产步骤，避免把流程压成一个长字符串。
model OrderLineProcessStep {
  id            String    @id @default(uuid())
  orderLineId   String
  orderLine     OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  stepNo        Int
  processName   String
  processRemark String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([orderLineId, stepNo])
  @@index([processName])
}

/// 生产任务由订单零件生成，状态按 PENDING -> IN_PROGRESS -> WAITING_CONFIRMATION -> COMPLETED -> STORED 流转。
model ProductionTask {
  id                           String                        @id @default(uuid())
  productionTaskNo             String                        @unique
  orderId                      String
  order                        CustomerOrder                 @relation(fields: [orderId], references: [id])
  orderLineId                  String
  orderLine                    OrderLine                     @relation(fields: [orderLineId], references: [id])
  orderNo                      String
  customerName                 String
  partCode                     String
  partName                     String
  plannedQuantity              Decimal                       @db.Decimal(18, 3)
  completedQuantity            Decimal                       @default(0) @db.Decimal(18, 3)
  unit                         String
  status                       ProductionStatus              @default(PENDING)
  processSnapshot              Json
  isReplenishment              Boolean                       @default(false)
  sourceProductionTaskNo       String?
  replenishmentSourceType      String?
  replenishmentSourceRequestNo String?
  startedAt                    DateTime?
  completedAt                  DateTime?
  remark                       String?
  inventoryBatch               InventoryBatch?
  processCompletions           ProductionProcessCompletion[]
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt

  @@index([orderId])
  @@index([orderNo])
  @@index([status])
  @@index([partCode])
  @@index([isReplenishment])
  @@index([sourceProductionTaskNo])
  @@index([replenishmentSourceType])
  @@index([replenishmentSourceRequestNo])
}

/// 生产操作人员基础账号，第一阶段只做工序确认需要的账号 ID、姓名、岗位和搜索字段。
model ProductionOperator {
  id             String       @id @default(uuid())
  accountId      String       @unique
  name           String
  role           String
  pinyin         String?
  pinyinInitials String?
  keywords       String[]     @default([])
  idCardMasked   String?
  idCardBound    Boolean      @default(false)
  status         CommonStatus @default(ENABLED)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([name])
  @@index([status])
}

/// 每道工序的完成表单；同一个生产任务的同一道工序只保留当前有效记录。
model ProductionProcessCompletion {
  id                       String                           @id @default(uuid())
  productionTaskId         String
  productionTask           ProductionTask                   @relation(fields: [productionTaskId], references: [id], onDelete: Cascade)
  stepNo                   Int
  processName              String
  processRemark            String?
  isCompleted              Boolean                          @default(false)
  completedQuantity        Decimal                          @default(0) @db.Decimal(18, 3)
  scrapQuantity            Decimal                          @default(0) @db.Decimal(18, 3)
  shortageQuantity         Decimal                          @default(0) @db.Decimal(18, 3)
  shortageMode             String?
  replenishmentTaskNo      String?
  managerName              String?
  shortageReason           String?
  shortageResolutionMode   String?
  shortageResolutionBy     String?
  shortageResolutionReason String?
  shortageResolvedAt       DateTime?
  unit                     String
  operatorCode             String?
  operatorName             String?
  operatorRole             String?
  completedAt              DateTime?
  quantityOverrideReason   String?
  remark                   String?
  replenishmentRequests    ProductionReplenishmentRequest[]
  logs                     ProductionProcessCompletionLog[]
  createdAt                DateTime                         @default(now())
  updatedAt                DateTime                         @updatedAt

  @@unique([productionTaskId, stepNo])
  @@index([processName])
  @@index([isCompleted])
  @@index([completedAt])
  @@index([shortageResolutionMode])
}

/// 工序完成表单修改日志，只追加，不覆盖。
model ProductionProcessCompletionLog {
  id               String                      @id @default(uuid())
  completionId     String
  completion       ProductionProcessCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)
  productionTaskId String
  processName      String
  action           String
  operatorCode     String?
  operatorName     String?
  beforeSnapshot   Json?
  afterSnapshot    Json
  createdAt        DateTime                    @default(now())

  @@index([completionId])
  @@index([productionTaskId])
  @@index([createdAt])
}

/// 生产过程中因报废、缺件发起的补单申请；和订单页面由销售/计划发起的数量增加补单分开记录。
model ProductionReplenishmentRequest {
  id                  String                       @id @default(uuid())
  requestNo           String                       @unique
  sourceType          String                       @default("PRODUCTION_SCRAP")
  status              String                       @default("PENDING")
  orderId             String?
  orderNo             String
  orderLineId         String?
  productionTaskId    String?
  productionTaskNo    String?
  processCompletionId String?                      @unique
  processCompletion   ProductionProcessCompletion? @relation(fields: [processCompletionId], references: [id], onDelete: SetNull)
  partCode            String
  partName            String
  requestQuantity     Decimal                      @db.Decimal(18, 3)
  scrapQuantity       Decimal                      @default(0) @db.Decimal(18, 3)
  unit                String
  reason              String
  requestedByCode     String?
  requestedByName     String?
  supervisorName      String?
  supervisorRemark    String?
  approvedAt          DateTime?
  reviewedAt          DateTime?
  replenishmentTaskNo String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  @@index([status])
  @@index([sourceType])
  @@index([orderNo])
  @@index([productionTaskNo])
  @@index([partCode])
  @@index([createdAt])
}

model ProductionNotice {
  id               String                 @id @default(uuid())
  noticeNo         String                 @unique
  noticeType       ProductionNoticeType
  status           ProductionNoticeStatus @default(PENDING)
  target           ProductionNoticeTarget @default(PRODUCTION)
  orderId          String?
  orderNo          String
  orderLineId      String?
  productionTaskId String?
  productionTaskNo String?
  partCode         String?
  partName         String?
  beforeQuantity   Decimal?               @db.Decimal(18, 3)
  afterQuantity    Decimal?               @db.Decimal(18, 3)
  deltaQuantity    Decimal?               @db.Decimal(18, 3)
  unit             String?
  reason           String
  managerName      String?
  handlingPlan     Json?
  acknowledgedBy   String?
  acknowledgedAt   DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([status])
  @@index([target])
  @@index([target, status])
  @@index([noticeType])
  @@index([orderNo])
  @@index([productionTaskNo])
  @@index([createdAt])
}

model ProductionScrapRecord {
  id               String   @id @default(uuid())
  scrapNo          String   @unique
  orderId          String?
  orderNo          String
  orderLineId      String?
  productionTaskId String?
  productionTaskNo String?
  partCode         String
  partName         String
  quantity         Decimal  @db.Decimal(18, 3)
  unit             String
  reason           String
  sourceRecordType String
  sourceRecordId   String
  recordDate       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([sourceRecordType, sourceRecordId])
  @@index([orderNo])
  @@index([productionTaskNo])
  @@index([partCode])
  @@index([recordDate])
}

model Warehouse {
  id                    String                 @id @default(uuid())
  warehouseCode         String                 @unique
  warehouseName         String
  status                CommonStatus           @default(ENABLED)
  locations             WarehouseLocation[]
  inventoryBatches      InventoryBatch[]
  inventoryTransactions InventoryTransaction[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model WarehouseLocation {
  id                    String                 @id @default(uuid())
  warehouseId           String
  warehouse             Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  locationCode          String
  locationName          String
  status                CommonStatus           @default(ENABLED)
  inventoryBatches      InventoryBatch[]
  inventoryTransactions InventoryTransaction[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@unique([warehouseId, locationCode])
}

model InventoryBatch {
  id                           String                 @id @default(uuid())
  batchNo                      String                 @unique
  partCode                     String
  partName                     String
  sourceOrderId                String?
  sourceOrder                  CustomerOrder?         @relation(fields: [sourceOrderId], references: [id])
  sourceOrderLineId            String?
  sourceOrderLine              OrderLine?             @relation(fields: [sourceOrderLineId], references: [id])
  sourceOrderNo                String?
  sourceCustomerName           String?
  productionTaskId             String?                @unique
  productionTask               ProductionTask?        @relation(fields: [productionTaskId], references: [id])
  sourceProductionTaskNo       String?
  sourceKind                   String                 @default("NORMAL_ORDER")
  replenishmentSourceType      String?
  replenishmentSourceRequestNo String?
  quantity                     Decimal                @db.Decimal(18, 3)
  unit                         String
  warehouseId                  String
  warehouse                    Warehouse              @relation(fields: [warehouseId], references: [id])
  locationId                   String?
  location                     WarehouseLocation?     @relation(fields: [locationId], references: [id])
  status                       InventoryStatus        @default(AVAILABLE)
  transactions                 InventoryTransaction[]
  adjustments                  InventoryAdjustment[]
  reservations                 InventoryReservation[]
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt

  @@index([partCode])
  @@index([sourceOrderNo])
  @@index([sourceOrderLineId])
  @@index([sourceProductionTaskNo])
  @@index([sourceKind])
  @@index([replenishmentSourceType])
  @@index([replenishmentSourceRequestNo])
  @@index([warehouseId])
  @@index([status])
}

/// 订单保存后对备货库存的预占记录。草稿订单不直接扣库存，提交生产时把 ACTIVE 预占转为 CONSUMED 并生成库存流水。
model InventoryReservation {
  id           String                     @id @default(uuid())
  batchId      String
  batch        InventoryBatch             @relation(fields: [batchId], references: [id])
  orderId      String
  order        CustomerOrder              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderLineId  String?
  orderLine    OrderLine?                 @relation(fields: [orderLineId], references: [id], onDelete: SetNull)
  orderNo      String
  partCode     String
  partName     String
  quantity     Decimal                    @db.Decimal(18, 3)
  unit         String
  status       InventoryReservationStatus @default(ACTIVE)
  statusReason String?
  releasedAt   DateTime?
  consumedAt   DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([batchId, status])
  @@index([orderId, status])
  @@index([orderLineId, status])
  @@index([orderNo])
  @@index([partCode])
}

/// 库存流水只追加记录，用于保留入库 / 出库数量变化。
model InventoryTransaction {
  id               String                   @id @default(uuid())
  transactionNo    String                   @unique
  transactionType  InventoryTransactionType
  batchId          String
  batch            InventoryBatch           @relation(fields: [batchId], references: [id])
  orderLineId      String?
  orderLine        OrderLine?               @relation(fields: [orderLineId], references: [id], onDelete: SetNull)
  partCode         String
  partName         String
  orderNo          String?
  productionTaskNo String?
  quantity         Decimal                  @db.Decimal(18, 3)
  unit             String
  warehouseId      String
  warehouse        Warehouse                @relation(fields: [warehouseId], references: [id])
  locationId       String?
  location         WarehouseLocation?       @relation(fields: [locationId], references: [id])
  transactionTime  DateTime                 @default(now())
  remark           String?
  sourceRecordType String?
  sourceRecordId   String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([transactionType])
  @@index([partCode])
  @@index([orderNo])
  @@index([orderLineId])
  @@index([transactionTime])
}

/// 仓库盘点调整记录：库存管理员修改批次数量时必须保留清点工单、清点人、日期和签字信息。
model InventoryAdjustment {
  id                 String         @id @default(uuid())
  adjustmentNo       String         @unique
  batchId            String
  batch              InventoryBatch @relation(fields: [batchId], references: [id])
  partCode           String
  partName           String
  beforeQuantity     Decimal        @db.Decimal(18, 3)
  afterQuantity      Decimal        @db.Decimal(18, 3)
  deltaQuantity      Decimal        @db.Decimal(18, 3)
  unit               String
  countedBy          String
  countedAt          DateTime
  signatureName      String
  attachmentFileName String?
  attachmentFileUrl  String?
  attachmentMimeType String?
  attachmentSize     Int?
  remark             String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([batchId])
  @@index([partCode])
  @@index([countedAt])
  @@index([createdAt])
}
