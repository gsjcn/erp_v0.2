{
  "name": "baisheng-erp-first-stage",
  "private": true,
  "version": "0.2.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "backend:dev": "npm --workspace backend run dev",
    "backend:build": "npm --workspace backend run build",
    "backend:start": "npm --workspace backend run start",
    "backend:db:generate": "npm --workspace backend run db:generate",
    "backend:db:migrate": "npm --workspace backend run db:migrate",
    "backend:db:deploy": "npm --workspace backend run db:deploy",
    "backend:db:seed": "npm --workspace backend run db:seed",
    "backend:verify:first-stage": "npm --workspace backend run verify:first-stage",
    "backend:repair:first-stage": "npm --workspace backend run repair:first-stage --",
    "verify:first-stage:source": "node scripts/verify-first-stage-source.cjs",
    "verify:first-stage:config": "node scripts/verify-first-stage-config.cjs",
    "verify:order-import-api": "node scripts/verify-order-import-api.cjs",
    "verify:material-import-api": "node scripts/verify-material-import-api.cjs",
    "verify:production-notices-api": "node scripts/verify-production-notices-api.cjs",
    "verify:upload-filenames-api": "node scripts/verify-upload-filenames-api.cjs",
    "verify:file-name-normalizers": "node scripts/verify-file-name-normalizers.cjs",
    "verify:prisma-client-enums": "node scripts/verify-prisma-client-enums.cjs",
    "verify:order-import-workbooks": "node scripts/verify-order-import-workbooks.cjs",
    "verify:first-stage:api": "node scripts/verify-first-stage-api.cjs",
    "verify:first-stage": "npm run verify:first-stage:source && npm run verify:first-stage:config && npm run verify:file-name-normalizers && npm run verify:prisma-client-enums && npm run verify:order-import-workbooks && npm run backend:verify:first-stage && npm run backend:build && npm run frontend:build",
    "verify:first-stage:strict": "npm run verify:first-stage:source && npm run verify:first-stage:config && npm run verify:file-name-normalizers && npm run verify:order-import-workbooks && npm run backend:db:generate && npm run verify:prisma-client-enums && npm run backend:verify:first-stage && npm run backend:build && npm run verify:first-stage:api && npm run frontend:build",
    "frontend:dev": "npm --workspace frontend run dev",
    "frontend:build": "npm --workspace frontend run build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  }
}
