{
  "name": "@baisheng/erp-backend",
  "private": true,
  "version": "0.2.0",
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "db:generate": "node scripts/prisma-with-root-env.cjs generate --schema ../database/prisma/schema.prisma",
    "db:migrate": "node scripts/prisma-with-root-env.cjs migrate dev --schema ../database/prisma/schema.prisma",
    "db:deploy": "node scripts/prisma-with-root-env.cjs migrate deploy --schema ../database/prisma/schema.prisma",
    "db:seed": "node scripts/prisma-with-root-env.cjs db seed --schema ../database/prisma/schema.prisma",
    "verify:first-stage": "tsx ../database/prisma/verify-first-stage.ts",
    "repair:first-stage": "tsx ../database/prisma/repair-first-stage.ts"
  },
  "prisma": {
    "seed": "tsx ../database/prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "multer": "^2.1.1",
    "pinyin-pro": "^3.28.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.19",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
